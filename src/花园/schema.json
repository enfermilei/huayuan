{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "系统": {
      "default": {},
      "type": "object",
      "properties": {
        "日期": {
          "default": "第1天",
          "type": "string"
        },
        "时间": {
          "default": "8:00",
          "type": "string"
        },
        "星期": {
          "default": "周一",
          "type": "string",
          "enum": [
            "周一",
            "周二",
            "周三",
            "周四",
            "周五",
            "周六",
            "周日"
          ]
        },
        "天气": {
          "default": "晴天",
          "type": "string"
        },
        "温度": {
          "default": "21°",
          "type": "string"
        },
        "组织全局": {
          "default": {},
          "type": "object",
          "properties": {
            "总资金": {
              "default": 0,
              "type": "number"
            },
            "组织声望": {
              "default": 0,
              "type": "number"
            },
            "近期事务": {
              "default": {},
              "type": "object",
