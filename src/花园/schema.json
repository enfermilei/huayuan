                    "default": "无",
                    "type": "string"
                  },
                  "距离开始时间": {
                    "default": "未知",
                    "type": "string"
                  },
                  "距离结束时间": {
                    "default": "未知",
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "金缕赌场": {
          "default": {},
          "type": "object",
          "properties": {
            "经营状况": {
              "default": "正常运营",
              "type": "string",
