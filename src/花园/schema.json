                  },
                  "涉及部门或职务": {
                    "default": "无",
                    "type": "string"
                  },
                  "距离开始时间": {
                    "default": "未知",
                    "type": "string"
                  },
                  "距离结束时间": {
                    "default": "未知",
                    "type": "string"
                  }
                }
              }
            },
            "近期大型活动": {
              "default": {},
              "type": "object",
              "propertyNames": {
                "type": "string",
                "description": "近期大型活动名"
              },
              "additionalProperties": {
                "default": {},
                "type": "object",
                "properties": {
                  "描述": {
                    "default": "无",
                    "type": "string"
                  },
                  "时间": {
                    "default": "未知",
                    "type": "string",
                    "description": "如XX年X月X日-XX年X月X日"
